MAC_RELEASE_OP_FIELDS='APP_STORE_CONNECT_KEY_ID APP_STORE_CONNECT_ISSUER_ID APP_STORE_CONNECT_API_KEY_P8'
MAC_RELEASE_OP_TMUX_SESSION='repobar-mac-release-op'
MAC_RELEASE_TAG_SIGNED=0
MAC_RELEASE_TAG_FORCE=1
MAC_RELEASE_GENERATE_APPCAST_ARGS='--maximum-deltas 0'
