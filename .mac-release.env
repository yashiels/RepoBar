# Older shared AGCY Sparkle key fallback. SPARKLE_PRIVATE_KEY_FILE still wins;
# Keychain is used when this local file is absent.
MAC_RELEASE_SIGNING_KEY_FILE='$HOME/Library/CloudStorage/Dropbox/Backup/Sparkle/sparkle-private-key-OBSOLETE-not-for-BlackBar-publickey-AGCY8w5vHirVfGGDGc8Szc5iuOqupZSh9pMj_Qs67XI-2026-05-21.txt'

MAC_RELEASE_APP_ZIP='RepoBar-${MARKETING_VERSION}.zip'
MAC_RELEASE_DSYM_ZIP='RepoBar-${MARKETING_VERSION}.dSYM.zip'
MAC_RELEASE_ARTIFACT_PREFIX='RepoBar-'
MAC_RELEASE_FEED_URL='https://raw.githubusercontent.com/steipete/RepoBar/main/appcast.xml'
MAC_RELEASE_DOWNLOAD_URL_PREFIX='https://github.com/steipete/RepoBar/releases/download/v${MARKETING_VERSION}/'

MAC_RELEASE_PRECHECK='swiftformat Sources Tests >/dev/null && swiftlint --strict && swift test'
MAC_RELEASE_PACKAGE_CMD='Scripts/sign-and-notarize.sh'
MAC_RELEASE_OP_ITEM='RepoBar App Store Connect API'
