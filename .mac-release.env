MAC_RELEASE_APP_NAME=RepoBar
MAC_RELEASE_REPO=steipete/RepoBar
MAC_RELEASE_BUNDLE_ID=com.steipete.repobar
MAC_RELEASE_VERSION_FILE=version.env
MAC_RELEASE_APPCAST=appcast.xml
